generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ============================================================
// User — an account holder (identified by phone number)
// Maps to the User class in SRS Appendix B.3
// ============================================================
model User {
  id              String   @id @default(cuid())
  phoneNumber     String   @unique
  preferredName   String?
  privatePinHash  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("users")
}

// ============================================================
// OtpRequest — a pending phone verification challenge
// Created when a user submits their phone; consumed when they enter the OTP.
// ============================================================
model OtpRequest {
  id          String   @id @default(cuid())
  phoneNumber String
  otpHash     String
  expiresAt   DateTime
  consumed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phoneNumber])
  @@map("otp_requests")
}